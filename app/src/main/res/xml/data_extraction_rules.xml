<?xml version="1.0" encoding="utf-8"?>
<!--
   Block Android Auto Backup and Device Transfer from copying the app's
   data. The relay/listener configs (bot tokens, channel ids, future
   passphrase) must not leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
