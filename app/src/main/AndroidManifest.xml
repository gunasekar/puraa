<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Read incoming SMS the instant they arrive. The SMS_RECEIVED
         broadcast hands us the message directly (sender, body, time). -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />

    <!-- Query the SMS inbox ONLY for the manual "push last 15 min" button
         (an explicit user-initiated backfill). Requested lazily on first
         use; the automatic relay never reads the provider. -->
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Post each SMS to Telegram over HTTPS. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- WorkManager runs the (expedited) send. On Android < 12 it does so
         as a brief foreground service; hence these + POST_NOTIFICATIONS. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Keep sends prompt even when the phone is idle. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Camera is used only to scan a setup QR code (optional feature). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".PuraaApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Puraa"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Puraa">
            <!-- LAUNCHER only. Puraa registers NO deep-link/VIEW handler: the
                 relay is configured solely by manual entry or by scanning a
                 self-contained setup QR (see config/SetupCode.kt), so there is
                 no exported, remotely-deliverable link that could re-point it. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WorkManager runs the expedited send as a brief foreground
             service on Android < 12; declare its type so the platform (and
             release lint) is satisfied. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- The SMS source. SMS_RECEIVED is exempt from Android 8+ implicit
             broadcast limits, so this fires even when the app isn't running
             and after a reboot — no boot receiver needed. -->
        <receiver
            android:name=".relay.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
